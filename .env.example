# Baiwa Weather environment variables
#
# NOAA / National Weather Service does NOT require an API key, but it does
# require a descriptive User-Agent. Set one to identify this app to NOAA.
# Example: "(baiwa-weather, contact@example.com)"
VITE_NOAA_USER_AGENT="(baiwa-weather, dev@example.com)"

# Optional: override the default Stripe Payment Link
# VITE_DONATE_URL=https://buy.stripe.com/your-link

# AccuWeather comparison panel when no key is provided.
# Get a free developer key at https://developer.accuweather.com/
VITE_ACCUWEATHER_API_KEY=
